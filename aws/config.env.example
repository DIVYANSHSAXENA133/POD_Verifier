# ============================================================
# POD pipeline — environment variable names (Lambda runtime)
#
# Values are set by CloudFormation (infra/stack.yaml) via
# aws/provision-stack.sh — do NOT bake secrets into the image.
# Never commit real API keys or DB passwords.
# ============================================================

# --- Metabase ---
METABASE_URL=https://metabase.example.com
METABASE_API_KEY=REPLACE_ME
METABASE_CARD_ID=10989

# --- Pipeline (stack parameters: FetchBatchSize, FlagThreshold, InferenceBatchSize) ---
FETCH_BATCH_SIZE=500
FLAG_THRESHOLD=0.7

# --- Postgres ---
PG_HOST=db.xxxxxxxx.region.rds.amazonaws.com
PG_PORT=5432
PG_DATABASE=pod_classifier
PG_USER=postgres
PG_PASSWORD=REPLACE_ME

# --- Model (inside image unless you extend stack.yaml) ---
MODEL_PATH=/opt/model/best.pt
INPUT_SIZE=224
INFERENCE_BATCH_SIZE=64

# --- S3 state bucket (auto-created by stack.yaml) ---
S3_STATE_BUCKET=pod-pipeline-state-prod-123456789012

# --- Provisioning examples (provision-stack.sh / deploy.sh exports) ---
# AWS_REGION=ap-south-1
# STACK_NAME=pod-scoring-prod
# STAGE=prod
# VPC_ID=vpc-xxx
# SUBNET_IDS=subnet-a,subnet-b
# SCORER_IMAGE_URI=account.dkr.ecr.region.amazonaws.com/repo:tag
# ECR_REPOSITORY=pod-pipeline
# TMP_EPHEMERAL_MB=5120
