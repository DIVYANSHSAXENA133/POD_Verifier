# ============================================================
# POD Scoring Pipeline — Environment Variables
# Copy to .env and fill in actual values before deployment.
# All values are configurable — nothing hardcoded for secrets.
# ============================================================

# --- Metabase ---
METABASE_URL=https://metabase.blitznow.in
METABASE_API_KEY=mb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
METABASE_CARD_ID=10989                # Card to query (10989=today, 10798=all verified)

# --- Lambda configuration (mirrors SAM FetchBatchSize / FlagThreshold / TmpEphemeralMB) ---
FETCH_BATCH_SIZE=500                  # POD images staged per batch under /tmp
FLAG_THRESHOLD=0.7                   # POD score threshold: >= PASS, < FLAG
STAGING_TMP_PATH=/tmp               # Writable staging root inside Lambda

# --- PostgreSQL (RDS) ---
PG_HOST=pod-scoring-db.xxxxxxxx.ap-south-1.rds.amazonaws.com
PG_PORT=5432
PG_DATABASE=pod_classifier
PG_USER=postgres
PG_PASSWORD=your-secure-password     # Use AWS Secrets Manager in production

# --- Model ---
MODEL_PATH=/opt/model/best.pt        # Baked into container image
INPUT_SIZE=224                        # EfficientNet input resolution
INFERENCE_BATCH_SIZE=64              # Inference micro-batch inside each fetch batch

# --- AWS Infrastructure (SAM parameters — not wired as Lambda env vars) ---
# STAGE=prod
# VPC_ID=vpc-xxxxxxxxx
# SUBNET_IDS=subnet-aaa,subnet-bbb
# SCORER_IMAGE_URI=123456789012.dkr.ecr.ap-south-1.amazonaws.com/pod-pipeline:latest
# TMP_EPHEMERAL_MB=5120               # Align with FetchBatchSize × typical image KB
